# VM Control Center — Environment Configuration
# Copy to .env and adjust for your deployment:
#   cp .env.example .env

# SSH access to remote Orchard worker hosts
VMCC_SSH_KEY=~/.ssh/my-key
VMCC_SSH_USER=admin
# VMCC_REMOTE_TART_PATH=/opt/homebrew/bin/tart

# Pipeline Controller (optional — enables Pipeline tab)
# VMCC_PIPELINE_CONTROLLER_URL=http://pipeline-host:3200

# Server bind (defaults: 127.0.0.1:8000)
# VMCC_HOST=0.0.0.0
# VMCC_PORT=8200
