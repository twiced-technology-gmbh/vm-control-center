# VM Control Center — Environment Configuration
# Copy to .env and adjust for your deployment:
#   cp .env.example .env

# SSH access to remote Orchard worker hosts
VMCC_SSH_KEY=~/.ssh/your-key
VMCC_SSH_USER=admin
# VMCC_REMOTE_TART_PATH=/opt/homebrew/bin/tart

# Caddy host for SSH-based Caddyfile edits (auto-detected from Orchard URL if unset)
# VMCC_CADDY_HOST=ddmini
# Path to caddy binary on the Caddy host (default: caddy)
# VMCC_CADDY_BINARY=/opt/homebrew/bin/caddy

# Server bind (defaults: 127.0.0.1:8000)
# VMCC_HOST=0.0.0.0
# VMCC_PORT=8200
